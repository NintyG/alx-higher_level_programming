#!/bin/bash

# Check if PYFILE environment variable is set
if [ -z "$PYFILE" ]; then
  echo "PYFILE environment variable not set."
  exit 1
fi

# Check if the Python file exists
if [ ! -f "$PYFILE" ]; then
  echo "Python file '$PYFILE' not found."
  exit 1
fi

# Run the Python script
python "$PYFILE"

# Exit with status code of the Python script
exit "$?"

